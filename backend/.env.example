# ============================================================
# ChemBind Backend — Environment Variables
# Copy to .env and fill in real values before deploying.
# ============================================================

# ---------- Redis ----------
# Upstash (prod): rediss://default:PASSWORD@HOST:PORT
# Local dev:      redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------- Firebase ----------
# Option A (file): path to service-account JSON
GOOGLE_APPLICATION_CREDENTIALS=./keys/firebase-service.json
# Option B (inline JSON, for Railway/Render where file mounts are awkward):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIRESTORE_PROJECT_ID=chembind-ccdbb

# ---------- Security ----------
# Comma-separated origins allowed by CORS (set to your Vercel URL in prod)
CORS_ORIGINS=
# Comma-separated allowed Host headers (include your API domain)
TRUSTED_HOSTS=localhost,127.0.0.1
# Rate-limit storage URI (redis:// for distributed, or leave empty for in-memory)
RATE_LIMIT_STORAGE_URI=

# ---------- Sentry ----------
SENTRY_DSN=
ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.0

# ---------- Celery / Worker ----------
CELERY_VISIBILITY_TIMEOUT_SECONDS=3600
CELERY_SOFT_TIME_LIMIT_SECONDS=540
CELERY_HARD_TIME_LIMIT_SECONDS=600
BATCH_PROGRESS_EVERY=10

# ---------- Limits ----------
MAX_BATCH_ROWS=500
MAX_REQUEST_BYTES=2097152
MAX_SMILES_LEN=500
MAX_ATOMS=200
REQUIRE_IDEMPOTENCY_KEY=true
IDEMPOTENCY_TTL_HOURS=24

# ---------- Feature Flags ----------
ENABLE_SIMILARITY_SEARCH=false

# ---------- Misc ----------
DEBUG=0
ANALYZE_TIMEOUT_S=2.5
LOG_LEVEL=INFO
